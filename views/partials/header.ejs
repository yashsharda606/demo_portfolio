<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.2/css/all.css">
  <link rel="stylesheet" href="/styles/layout.css">
  <link rel="stylesheet" href="/styles/content.css">
  <title>EJS Partials</title>
  <audio id="bg-music" autoplay>
    <source src="/song.mp3" type="audio/mpeg" />
  </audio>
</head>

<header>
  <nav class="navbar navbar-expand-custom navbar-mainbg">
    <a class="navbar-brand navbar-logo" href="#">My Portfolio</a>
    <button class="navbar-toggler" type="button" aria-controls="navbarSupportedContent" aria-expanded="false"
      aria-label="Toggle navigation">
      <i class="fas fa-bars text-white"></i>
    </button>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav ml-auto">
        <div class="hori-selector">
          <div class="left"></div>
        </div>

        <button id="stop-btn" onclick="stopMusic()">⏹ Stop</button>


        <li class="nav-item">
          <a class="nav-link" href="/"><i class="far fa-copy"></i>Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/about"><i class="far fa-clone"></i>About</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/contact"><i class="far fa-calendar-alt"></i>Contact</a>
        </li>

      </ul>
    </div>
  </nav>
</header>
<main class="container">

<script>
  const music = document.getElementById("bg-music");
  const stopBtn = document.getElementById("stop-btn");

  music.loop = false;

  // Start playing on first user interaction (browser autoplay policy)
  window.addEventListener("click", () => {
    if (music.paused) music.play();
  }, { once: true });

  // Hide stop button when song ends naturally
  music.addEventListener("ended", () => {
    stopBtn.style.display = "none";
  });

  function stopMusic() {
    music.pause();
    music.currentTime = 0;
    stopBtn.style.display = "none";
  }
</script>